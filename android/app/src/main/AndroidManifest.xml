<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Live Copilot transcribes the interviewer's audio during a call -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- Optional: "use my current location" in onboarding to prefill the job location. -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Android 11+ package visibility: needed to reach the on-device speech recognizer. -->
    <queries>
        <intent>
            <action android:name="android.speech.RecognitionService" />
        </intent>
    </queries>

    <application
        android:name=".AscendApp"
        android:allowBackup="true"
        android:fullBackupContent="@xml/backup_rules"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:localeConfig="@xml/locales_config"
        android:theme="@style/Theme.Ascend">

        <!-- AdMob App ID (Google Mobile Ads). Value injected per build type via the
             admobAppId manifest placeholder — sample/test id by default, real id in
             release from local.properties. Required or MobileAds.initialize crashes. -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="${admobAppId}" />

        <!-- Resolve the AdServices config <property> conflict: play-services-ads and the
             Firebase/measurement + UMP SDKs each declare android.adservices.AD_SERVICES_CONFIG
             with a different resource. Pin the GMA one so the manifest merger succeeds. -->
        <property
            android:name="android.adservices.AD_SERVICES_CONFIG"
            android:resource="@xml/gma_ad_services_config"
            tools:replace="android:resource" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Ascend.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
